%% docs/architecture.mmd — project-scaffolding's own internal structure.
%% Hand-authored, not generated — this is the per-repo counterpart to the
%% fleet-wide map `fleet-config`'s `/system-map` aggregates from every repo's
%% `.fleet.toml`. That map is mechanically crawled; this repo's own internal
%% shape is semantic and can't be, so it is authored once and kept correct by
%% discipline. Update this diagram in the same PR as any material structural
%% change (a new view, a new vendored component, a script relocated) — same
%% anti-staleness contract as this repo's own `.fleet.toml` `description` field.
%% See `ferraroroberto/fleet-config#256` for the general convention.

flowchart TB
  subgraph launchers["Launchers"]
    LAUNCHAPP["launch_app.{bat,sh}\nlocal Streamlit run"]
    LAUNCHSRV["launch_server.{bat,sh}\nlocal run + Cloudflare Tunnel"]
    TRAYTMPL["tray.bat.template\ncopy-to-adapt tray launcher\n(--restart: detect/kill/reclaim/start)"]
  end

  subgraph appdir["app/ — Streamlit UI"]
    APPPY["app.py\npage config, sidebar,\nlight/dark toggle, st.navigation"]
    VIEWS["views/\nwelcome.py, pipeline_runner.py\none render() per file"]
    TRAYLIB["tray/\nsingle_instance.py (named-mutex primitive, vendor-verbatim)"]
    WEBVEND["webapp/static/_vendored/\nnav/ (bottom-tab nav) · icons/ (Lucide sprite)\ncard/ · disclosure/ · modal/\nempty-state/ · switch/ · icon-tile/ · button/\nrange-tab/ · page-foot/ · home-head/ · select-native/\n+ demo.html (gallery / render harness)"]
    STYLES["styles/light.css\nruntime CSS overlay"]
    STCFG[".streamlit/config.toml\nnative dark theme"]
  end
  APPPY --> VIEWS
  APPPY --> STCFG
  APPPY --> STYLES
  LAUNCHAPP --> APPPY
  LAUNCHSRV --> APPPY
  TRAYTMPL -.->|calls by path, not vendored (#153)| FLEETCFGTRAY["fleet-config: tray/tray_lifecycle.ps1\nONE shared machine-local copy\n(external repo, ~/.claude/tray junction)"]

  subgraph srcdir["src/ — non-UI Python (reusable from CLI + tests)"]
    CONFIG["config.py\npaths + env-driven settings"]
    LOGGER["logger.py\nterminal + rotating file +\nStreamlit live panel, one log.info() call"]
    PIPELINES["pipelines/\nexample_pipeline.py\none run() per file, returns summary dict"]
    NOTIFY["notify/\nbase.py, factory.py, config.py, telegram.py\nvendor-verbatim Telegram notifier"]
    DOCCAP["doc_capture/\nengine.py + adapters.py (streamlit | url)\n+ launch.py + __main__.py (CLI)\nvendor-verbatim doc-capture screenshot engine\n(manifest-driven, fail-safe-masked,\ninput-hash-idempotent + README tour regen)"]
  end
  VIEWS -->|orchestrates, business logic stays here| PIPELINES
  VIEWS --> LOGGER
  PIPELINES --> LOGGER
  PIPELINES --> CONFIG
  LOGGER -->|writes| DATALOGS
  PIPELINES -.->|optional| NOTIFY

  DATALOGS["data/\nlogs/app.log, input/, output/\n(gitignored)"]

  subgraph scriptsdir["scripts/"]
    VERIFY["verify-before-ship.ps1\nbyte-compile -> ruff -> mypy --strict\n(vendored primitives) -> pytest (non-e2e)\n-> routed e2e (skip/static/full)"]
    CLASSIFY["classify_e2e.py (vendor-verbatim, #180)\ndiff-proportionate e2e routing\nreads .fleet.toml [e2e] rules, fail-safe to full"]
    TSCERT["gen_tailscale_cert.py\nprovision/renew Tailscale HTTPS leaf"]
    BRANDGEN["brand_gen.py\nrender_set(): Lucide master SVG -> dark-tile\nPWA/tray/Stream Deck icon set (resvg-py)"]
  end
  VERIFY --> srcdir
  VERIFY --> appdir
  VERIFY --> testsdir
  VERIFY -->|routes e2e phase via| CLASSIFY
  CLASSIFY -.->|reads [e2e] rules from| FLEETTOML

  subgraph branddir["brand/ — fleet icon masters"]
    BRANDSVGS["catalog.json + 20 curated identity SVGs\nvendored verbatim from lucide-static"]
  end
  BRANDGEN -->|reads| BRANDSVGS
  BRANDGEN -.->|imported via known local path by| DOWNSTREAM["downstream projects'\nscripts/gen_icons.py\n(app-launcher, photo-ocr, voice-transcriber,\nlocal-llm-hub, whatsapp-radar, home-automation)"]

  subgraph testsdir["tests/"]
    UNIT["test_*.py\none file per src/ module, hermetic\n(incl. test_doc_capture.py — browserless\nplan/hash/readme/adapter contract)"]
    E2E["e2e/conftest.py + test_smoke.py\npytest-playwright, force-restarts\nStreamlit via _streamlit_lifecycle.py\n+ test_vendored_components.py\n(drives _vendored/demo.html, light+dark)\n+ test_vendored_nav.py\n(mounts _vendored/nav skeleton, desktop+pill)"]
    GEOM["e2e/_geometry.py (vendor-verbatim, #157)\neffective 44px targets · overlap · overflow\nChart.js config reads · viewport x theme matrix\n+ test_geometry_helper.py\n+ _fixtures/geometry/ (hermetic twins + Chart.js)"]
    TRAYBEHAVIOR["e2e/test_tray_lifecycle_behavior.py\nWindows-only, pytest.mark.slow, no browser\ndrives real tray.bat + the canonical tray_lifecycle.ps1\nvia _tray_harness.py's resolve_tray_lifecycle_path()\n+ _dummy_tray_app.py"]
  end
  E2E --> appdir
  TRAYBEHAVIOR -->|materializes + drives| TRAYTMPL
  TRAYBEHAVIOR -->|resolves (shared path, falls back to\nfleet-config primary checkout), drives real lifecycle| FLEETCFGTRAY

  subgraph docsdir["docs/ — didactic references"]
    AGENTSDIR["agents/\nCLAUDE.master.md, AGENTS.master.md,\nADAPT_PROMPT.md, ROLLOUT_RUNBOOK.md"]
    TRAYDOC["windows-tray.md"]
    ONBOARD["app-onboarding.md"]
    PLAYWRIGHTDOC["playwright-ui-testing.md"]
    CHROMEDOC["shared-chrome-profile.md"]
    BRANDDOC["brand-icons.md"]
  end
  AGENTSDIR -.->|source of truth for| CLAUDEMD
  TRAYDOC -.->|documents| TRAYLIB
  TRAYDOC -.->|documents ownership of| FLEETCFGTRAY
  ONBOARD -.->|links| TRAYDOC
  BRANDDOC -.->|documents| BRANDGEN

  CLAUDEMD["CLAUDE.md\n(+ one-line AGENTS.md pointer)\nagent conventions for derived repos"]
  FLEETTOML[".fleet.toml\nfleet-map card + [e2e] routing rules (#180)"]

  subgraph external["External dependencies"]
    STREAMLIT["Streamlit"]
    CLOUDFLARE["Cloudflare Tunnel"]
    TELEGRAM["Telegram Bot API"]
    TAILSCALE["Tailscale (tailscale cert)"]
    PLAYWRIGHT["Playwright"]
    RUFFMYPY["ruff / mypy / pytest"]
    RESVG["resvg-py\n(SVG -> PNG rasterizer, prebuilt wheel)"]
  end
  APPPY --> STREAMLIT
  LAUNCHSRV --> CLOUDFLARE
  NOTIFY --> TELEGRAM
  TSCERT --> TAILSCALE
  E2E --> PLAYWRIGHT
  GEOM --> PLAYWRIGHT
  DOCCAP -.->|capture time only| PLAYWRIGHT
  VERIFY --> RUFFMYPY
  BRANDGEN --> RESVG
